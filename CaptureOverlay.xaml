<Window x:Class="JunkyScreenShot.CaptureOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="JunkyScreenShot Capture"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Cursor="Cross"
        Background="Black">
    <Grid>
        <!-- Frozen screenshot as the background, so the screen looks paused. -->
        <Image x:Name="ScreenshotImage" Stretch="Fill"/>

        <!-- Semi-transparent dark layer; a hole is cut out over the current selection. -->
        <Path x:Name="DimPath" Fill="#7F000000"/>

        <Canvas x:Name="OverlayCanvas">
            <!-- Pen strokes drawn by the user; clipped to the selection rectangle. -->
            <Canvas x:Name="StrokeLayer" IsHitTestVisible="False"/>

            <!-- Blue selection border (window highlight or drag rectangle). -->
            <Rectangle x:Name="SelectionBorder"
                       Stroke="#FF2D8CFF" StrokeThickness="2"
                       Visibility="Collapsed" IsHitTestVisible="False"/>

            <!-- "640 x 360 px" size label near the selection. -->
            <Border x:Name="SizeLabel" Background="#CC202020" CornerRadius="3"
                    Padding="6,2" Visibility="Collapsed" IsHitTestVisible="False">
                <TextBlock x:Name="SizeText" Foreground="White" FontSize="12"/>
            </Border>

            <!-- Confirmation toolbar shown after an area is selected. -->
            <Border x:Name="Toolbar" Background="#F2FFFFFF" CornerRadius="4"
                    Padding="4" Visibility="Collapsed"
                    BorderBrush="#FF888888" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="PenButton" Content="Pen" Margin="2" Padding="12,4" Click="PenButton_Click"/>
                    <Button Content="Undo" Margin="2" Padding="12,4" Click="UndoButton_Click"/>
                    <Button Content="Copy" Margin="2" Padding="12,4" Click="CopyButton_Click"/>
                    <Button Content="Save" Margin="2" Padding="12,4" Click="SaveButton_Click"/>
                    <Button Content="QuickSave" Margin="2" Padding="12,4" Click="QuickSaveButton_Click"/>
                    <Button Content="Pin" Margin="2" Padding="12,4" Click="PinButton_Click"/>
                    <Button Content="Cancel" Margin="2" Padding="12,4" Click="CancelButton_Click"/>
                </StackPanel>
            </Border>

            <!-- Pen palette (stroke sizes + colors), shown while the pen tool is active. -->
            <Border x:Name="PenPalette" Background="#F2FFFFFF" CornerRadius="4"
                    Padding="4" Visibility="Collapsed"
                    BorderBrush="#FF888888" BorderThickness="1">
                <StackPanel x:Name="PalettePanel" Orientation="Horizontal"/>
            </Border>
        </Canvas>
    </Grid>
</Window>
